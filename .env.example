ASSISTANT_HAS_OWN_NUMBER=
TELEGRAM_BOT_TOKEN=
OLLAMA_HOST=

# Dashboard authentication
SESSION_SECRET=          # Required — random string for HMAC session signing

# Dashboard paths (defaults work if running from project root)
NANOCLAW_ROOT=           # Optional — absolute path to nanoclaw project root
NANOCLAW_STORE=          # Optional — absolute path to store/ directory
NANOCLAW_API_PORT=3939   # Port for NanoClaw backend API

# Local model routing (per-group model.json overrides)
SHIM_PORT=8089
OLLAMA_BASE_URL=http://studio.shearer.live:11434
OLLAMA_DEFAULT_MODEL=phi4:14b

# Database backend: 'dual' = SQLite (message bus) + PG (application DB)
# This is the permanent architecture, not a migration state.
DATA_BACKEND=dual
OLLAMA_TIMEOUT_MS=120000
OLLAMA_NUM_CTX=16384
